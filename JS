// MODULE 4: INTEGRISANI PREGLED

// ══════════════════════════════════════════════════════════════════════════════

function IntegrisaniPregled({ rows, monthlyData }) {

  if (!monthlyData.length) return null;

  const last = monthlyData[monthlyData.length-1];



  // Signal score computation

  const scores = [

    { label:"Prihodi", v: variance(last.prihodi_p, last.prihodi_o), inv:false },

    { label:"EBITDA marža", v: variance(last.ebitda_margin_p, last.ebitda_margin_o), inv:false },

    { label:"COGS efikasnost", v: variance(last.cogs_p, last.cogs_o), inv:true },

    { label:"Novi kupci", v: variance(last.novi_kupci_p, last.novi_kupci_o), inv:false },

    { label:"DSO", v: variance(last.potrazivanja_p, last.potrazivanja_o), inv:true },

    { label:"Prodajni ciklus", v: variance(last.ciklus_p, last.ciklus_o), inv:true },

    { label:"Zalihe", v: variance(last.zalihe_p, last.zalihe_o), inv:true },

    { label:"ARPA trend", v: variance(last.prihodi_p/Math.max(1,last.aktivni_p), last.prihodi_o/Math.max(1,last.aktivni_o)), inv:false },

  ].map(s => ({

    ...s,

    signal: s.inv ? (s.v < -5 ? "🔴" : s.v < 0 ? "🟡" : "🟢") : (s.v > 5 ? "🟢" : s.v > 0 ? "🟡" : "🔴"),

    score: s.inv ? (s.v < -5 ? 0 : s.v < 0 ? 1 : 2) : (s.v > 5 ? 2 : s.v > 0 ? 1 : 0),

  }));



  const totalScore = scores.reduce((a,s) => a+s.score, 0);

  const maxScore = scores.length * 2;

  const scoreRatio = totalScore / maxScore;

  const healthColor = scoreRatio >= 0.7 ? C.green : scoreRatio >= 0.4 ? C.gold : C.red;

  const healthLabel = scoreRatio >= 0.7 ? "DOBRO" : scoreRatio >= 0.4 ? "PAŽNJA" : "KRITIČNO";



  // Radar-style summary data

  const radarData = monthlyData.map(m => ({

    mesec: m.mesec,

    "Prihodi %": m.prihodi_p ? (m.prihodi_o/m.prihodi_p*100) : 100,

    "EBITDA %": m.ebitda_p ? (m.ebitda_o/m.ebitda_p*100) : 100,

    "Kupci %": m.novi_kupci_p ? (m.novi_kupci_o/m.novi_kupci_p*100) : 100,

  }));



  const cogsToRevData = monthlyData.map(m => ({

    mesec: m.mesec,

    "COGS/Rev Plan": m.prihodi_p ? +(m.cogs_p/m.prihodi_p*100).toFixed(1) : 0,

    "COGS/Rev Ost": m.prihodi_o ? +(m.cogs_o/m.prihodi_o*100).toFixed(1) : 0,

  }));



  return (

    <div>

      <SectionHeader icon="🔗" title="Integrisani Pregled" sub="Međuzavisnost finansijskog · operacionog · prodajnog kontrolinga" />



      {/* Health Score */}

      <div style={{ background:C.card, border:`2px solid ${healthColor}44`, borderRadius:12, padding:20, marginBottom:24 }}>

        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", flexWrap:"wrap", gap:12 }}>

          <div>

            <div style={{ fontSize:11, color:C.muted, textTransform:"uppercase", letterSpacing:"0.1em", marginBottom:6 }}>Ukupni zdravstveni skor firme</div>

            <div style={{ fontSize:42, fontWeight:900, color:healthColor, letterSpacing:"-0.03em" }}>{totalScore}/{maxScore}</div>

            <div style={{ fontSize:16, fontWeight:700, color:healthColor, marginTop:4 }}>{healthLabel}</div>

          </div>

          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8, flex:1, maxWidth:480 }}>

            {scores.map((s,i) => (

              <div key={i} style={{ display:"flex", alignItems:"center", gap:8, padding:"6px 10px", background:C.surface, borderRadius:6 }}>

                <span style={{ fontSize:14 }}>{s.signal}</span>

                <span style={{ fontSize:12, color:C.muted }}>{s.label}</span>

                <span style={{ fontSize:12, color:varColor(s.v, s.inv), fontWeight:600, marginLeft:"auto" }}>

                  {varSign(s.v)}{Math.abs(s.v).toFixed(1)}%

                </span>

              </div>

            ))}

          </div>

        </div>

      </div>



      {/* Ostvarenje % po oblastima */}

      <div style={{ background:C.card, border:`1px solid ${C.border}`, borderRadius:10, padding:16, marginBottom:24 }}>

        <div style={{ fontSize:13, fontWeight:700, color:C.text, marginBottom:12 }}>% Ostvarenja plana — Prihodi · EBITDA · Kupci</div>

        <ResponsiveContainer width="100%" height={220}>

          <LineChart data={radarData} margin={{top:0,right:10,left:0,bottom:0}}>

            <CartesianGrid strokeDasharray="3 3" stroke={C.dim} />

            <XAxis dataKey="mesec" tick={{fill:C.muted,fontSize:11}} axisLine={false} tickLine={false} />

            <YAxis unit="%" tick={{fill:C.muted,fontSize:11}} axisLine={false} tickLine={false} domain={[70,130]} />

            <Tooltip content={<CustomTooltip />} />

            <Legend wrapperStyle={{fontSize:12,color:C.muted}} />

            <ReferenceLine y={100} stroke={C.muted} strokeDasharray="6 3" label={{ value:"Plan=100%", fill:C.muted, fontSize:11 }} />

            <Line dataKey="Prihodi %" stroke={C.accent} strokeWidth={2.5} dot={{r:3}} />

            <Line dataKey="EBITDA %" stroke={C.gold} strokeWidth={2.5} dot={{r:3}} />

            <Line dataKey="Kupci %" stroke={C.green} strokeWidth={2.5} dot={{r:3}} />

          </LineChart>

        </ResponsiveContainer>

      </div>



      {/* COGS/Rev ratio */}

      <div style={{ background:C.card, border:`1px solid ${C.border}`, borderRadius:10, padding:16, marginBottom:24 }}>

        <div style={{ fontSize:13, fontWeight:700, color:C.text, marginBottom:4 }}>Operaciona efikasnost → Finansijski efekat: COGS/Prihodi (%)</div>

        <div style={{ fontSize:11, color:C.muted, marginBottom:12 }}>Porast ovog racia direktno erodira bruto i EBITDA maržu</div>

        <ResponsiveContainer width="100%" height={180}>

          <ComposedChart data={cogsToRevData} margin={{top:0,right:10,left:0,bottom:0}}>

            <CartesianGrid strokeDasharray="3 3" stroke={C.dim} />

            <XAxis dataKey="mesec" tick={{fill:C.muted,fontSize:11}} axisLine={false} tickLine={false} />

            <YAxis unit="%" tick={{fill:C.muted,fontSize:11}} axisLine={false} tickLine={false} domain={[30,50]} />

            <Tooltip content={<CustomTooltip />} />

            <Legend wrapperStyle={{fontSize:12,color:C.muted}} />

            <Bar dataKey="COGS/Rev Plan" fill={C.dim} radius={[3,3,0,0]} />

            <Bar dataKey="COGS/Rev Ost" fill={C.red} radius={[3,3,0,0]} opacity={0.85} />

          </ComposedChart>

        </ResponsiveContainer>

      </div>



      {/* Integrisana matrica */}

      <div style={{ background:C.card, border:`1px solid ${C.border}`, borderRadius:10, padding:20 }}>

        <div style={{ fontSize:13, fontWeight:700, color:C.text, marginBottom:16 }}>Matrica međuzavisnosti — Efekat lančanog prenosa</div>

        <div style={{ display:"flex", flexDirection:"column", gap:1 }}>

          {[

            { from:"📈 Prodajni", to:"💰 Finansijski", effect:"Rast prihoda poboljšava EBITDA maržu samo ako je COGS pod kontrolom", status: variance(last.prihodi_p, last.prihodi_o) > 0 },

            { from:"⚙️ Operacioni", to:"💰 Finansijski", effect:"Skraćivanje DSO i DIO oslobađa gotovinu i smanjuje kamatne troškove", status: variance(last.potrazivanja_p, last.potrazivanja_o) < 0 },

            { from:"📈 Prodajni", to:"⚙️ Operacioni", effect:"Kraći prodajni ciklus smanjuje WIP zalihe i pritisak na radni kapital", status: variance(last.ciklus_p, last.ciklus_o) < 0 },

            { from:"⚙️ Operacioni", to:"📈 Prodajni", effect:"Niži COGS/Rev dozvoljava fleksibilniju cenovnu politiku i veće komisije", status: variance(last.cogs_p/Math.max(1,last.prihodi_p), last.cogs_o/Math.max(1,last.prihodi_o)) < 0 },

          ].map((rel,i) => (

            <div key={i} style={{ display:"flex", alignItems:"flex-start", gap:14, padding:"12px 14px", background: i%2===0?C.surface:C.card, borderRadius:6 }}>

              <span style={{ fontSize:18 }}>{rel.status ? "✅" : "⚠️"}</span>

              <div>

                <div style={{ fontSize:12, color:C.accent, fontWeight:700, marginBottom:3 }}>

                  {rel.from} → {rel.to}

                </div>

                <div style={{ fontSize:12, color:C.muted }}>{rel.effect}</div>

              </div>

            </div>

          ))}

        </div>

      </div>

    </div>

  );

}



