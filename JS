    const r = parseCSV(SAMPLE_CSV);

    setRows(r);

    setMonthlyData(buildMonthlyData(r));

    setLoaded(true);

  };



  const handleFile = useCallback((file) => {

    if (!file) return;

    const reader = new FileReader();

    reader.onload = (e) => {

      try {

        let text = e.target.result;

        const r = parseCSV(text);

        setRows(r);

        setMonthlyData(buildMonthlyData(r));

        setLoaded(true);

      } catch(err) {

        alert("Greška pri parsiranju fajla. Proveri format.");

      }

    };

    reader.readAsText(file, "UTF-8");

  }, []);



  const tabs = [

    { key:"finansijski", label:"Finansijski", icon:"💰" },

    { key:"operacioni",  label:"Operacioni",  icon:"⚙️" },

    { key:"prodajni",    label:"Prodajni",    icon:"📈" },

    { key:"integrisani", label:"Integrisani", icon:"🔗" },

  ];



  return (

    <div style={{ minHeight:"100vh", background:C.bg, color:C.text, fontFamily:"'DM Sans', 'Segoe UI', sans-serif" }}>

      {/* Header */}

      <div style={{ background:C.surface, borderBottom:`1px solid ${C.border}`, padding:"0 32px" }}>

        <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", height:56, maxWidth:1200, margin:"0 auto" }}>

          <div style={{ display:"flex", alignItems:"center", gap:12 }}>

            <div style={{ width:32, height:32, background:`linear-gradient(135deg,${C.accentD},${C.accent})`, borderRadius:8, display:"flex", alignItems:"center", justifyContent:"center", fontSize:16 }}>📊</div>

            <div>

              <div style={{ fontSize:15, fontWeight:800, color:C.text, letterSpacing:"-0.01em" }}>Kontroling Pro</div>

              <div style={{ fontSize:10, color:C.muted, letterSpacing:"0.08em", textTransform:"uppercase" }}>Plan · Ostvarenje · Analiza</div>

            </div>

          </div>



          {loaded && (

            <div style={{ display:"flex", gap:4 }}>

              {tabs.map(t => (

                <button key={t.key} onClick={() => setTab(t.key)}

                  style={{ padding:"7px 16px", borderRadius:6, border:"none", cursor:"pointer", fontSize:12, fontWeight:600,

                    background: tab===t.key ? C.accent : "transparent",

                    color: tab===t.key ? "#fff" : C.muted,

                    transition:"all 0.15s"

                  }}>

                  <span style={{ marginRight:5 }}>{t.icon}</span>{t.label}

                </button>

              ))}

            </div>

          )}



          <button onClick={() => { fileRef.current?.click(); }}

            style={{ padding:"7px 16px", borderRadius:6, border:`1px solid ${C.border}`, background:"transparent", color:C.muted, cursor:"pointer", fontSize:12 }}>

            ⬆ Upload CSV

          </button>

          <input ref={fileRef} type="file" accept=".csv,.txt" style={{ display:"none" }} onChange={e => handleFile(e.target.files[0])} />

        </div>

      </div>



      {/* Body */}

      <div style={{ maxWidth:1200, margin:"0 auto", padding:"32px 32px" }}>



        {!loaded ? (

          /* Landing */

          <div style={{ display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", minHeight:"70vh", gap:24 }}>

            <div style={{ textAlign:"center", maxWidth:560 }}>

              <div style={{ fontSize:48, marginBottom:16 }}>📊</div>

              <h1 style={{ margin:0, fontSize:32, fontWeight:900, color:C.text, letterSpacing:"-0.03em" }}>Kontroling Pro</h1>

              <p style={{ color:C.muted, fontSize:15, marginTop:12, lineHeight:1.6 }}>

                Kompletan alat za finansijski, operacioni i prodajni kontroling.<br />

                Uploaduj CSV fajl ili učitaj demo podatke.

              </p>

            </div>



            {/* Drop zone */}

            <div

              onDragOver={e => { e.preventDefault(); setDragging(true); }}

              onDragLeave={() => setDragging(false)}

              onDrop={e => { e.preventDefault(); setDragging(false); handleFile(e.dataTransfer.files[0]); }}

              style={{

                border: `2px dashed ${dragging ? C.accent : C.border}`,

                borderRadius: 12, padding: "40px 60px", textAlign:"center",

                background: dragging ? C.accent+"11" : C.card,

                cursor:"pointer", transition:"all 0.2s", minWidth:380

              }}

              onClick={() => fileRef.current?.click()}

            >

              <div style={{ fontSize:36, marginBottom:12 }}>📂</div>

              <div style={{ color:C.text, fontWeight:600, marginBottom:6 }}>Prevuci CSV fajl ovde</div>

              <div style={{ color:C.muted, fontSize:13 }}>ili klikni da odabereš fajl</div>

            </div>



            <div style={{ display:"flex", alignItems:"center", gap:16 }}>

              <div style={{ height:1, width:100, background:C.border }} />

              <span style={{ color:C.dim, fontSize:13 }}>ili</span>

              <div style={{ height:1, width:100, background:C.border }} />

            </div>



            <button onClick={loadSample}

              style={{ padding:"13px 36px", background:`linear-gradient(135deg,${C.accentD},${C.accent})`, color:"#fff", border:"none", borderRadius:8, cursor:"pointer", fontSize:15, fontWeight:700, letterSpacing:"-0.01em" }}>

              Učitaj demo podatke

            </button>



            {/* CSV format */}

            <div style={{ background:C.card, border:`1px solid ${C.border}`, borderRadius:10, padding:20, maxWidth:640, width:"100%" }}>

              <div style={{ fontSize:12, fontWeight:700, color:C.accent, marginBottom:10, textTransform:"uppercase", letterSpacing:"0.08em" }}>Format CSV fajla</div>

              <div style={{ fontSize:12, color:C.muted, lineHeight:1.8 }}>

                <strong style={{color:C.text}}>Obavezne kolone:</strong> Kategorija, Podkategorija, [Mes]_Plan, [Mes]_Ostvarenje<br />

                <strong style={{color:C.text}}>Kategorije:</strong> Prihodi · COGS · OpEx · Troškovi prodaje · Broj kupaca · Prodajni ciklus · Zalihe · Potraživanja<br />

                <strong style={{color:C.text}}>Meseci:</strong> Jan, Feb, Mar, Apr, Maj, Jun, Jul, Avg, Sep, Okt, Nov, Dec<br />

                <strong style={{color:C.text}}>Primer:</strong> Jan_Plan, Jan_Ostvarenje, Feb_Plan, Feb_Ostvarenje...

              </div>

            </div>

          </div>

        ) : (

          <div>

            {tab === "finansijski" && <FinancijskiKontroling rows={rows} monthlyData={monthlyData} />}

            {tab === "operacioni"  && <OperacioniKontroling  rows={rows} monthlyData={monthlyData} />}

            {tab === "prodajni"    && <ProdajniKontroling    rows={rows} monthlyData={monthlyData} />}

            {tab === "integrisani" && <IntegrisaniPregled    rows={rows} monthlyData={monthlyData} />}

          </div>

        )}

      </div>

    </div>

  );

}
return (
    <div style={{ backgroundColor: C.bg, minHeight: '100vh', color: C.text }}>
       {/* UI Dashboard-a */}
    </div>
  );
}


