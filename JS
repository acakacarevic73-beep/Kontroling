  const m = lastM.mesec;



  const tableRows = rows.map(r => {

    const pKey = `${m}_Plan`;

    const oKey = `${m}_Ostvarenje`;

    const p = r[pKey] || 0;

    const o = r[oKey] || 0;

    const v = variance(p, o);

    const isCost = ["COGS","OpEx","Troškovi prodaje"].includes(r.Kategorija);

    return { ...r, p, o, v, isCost };

  });



  return (

    <div style={{ overflowX:"auto" }}>

      <table style={{ width:"100%", borderCollapse:"collapse", fontSize:13 }}>

        <thead>

          <tr style={{ borderBottom:`2px solid ${C.border}` }}>

            {["Kategorija","Pozicija","Plan","Ostvarenje","Apsolutna var.","% var."].map(h => (

              <th key={h} style={{ textAlign: h==="Kategorija"||h==="Pozicija"?"left":"right", padding:"8px 12px", color:C.muted, fontWeight:600, fontSize:11, textTransform:"uppercase", letterSpacing:"0.06em" }}>{h}</th>

            ))}

          </tr>

        </thead>

        <tbody>

          {tableRows.map((r,i) => {

            const col = varColor(r.v, r.isCost);

            return (

              <tr key={i} style={{ borderBottom:`1px solid ${C.border}`, background: i%2===0?C.surface:C.card }}>

                <td style={{ padding:"8px 12px", color:C.muted, fontSize:12 }}>{r.Kategorija}</td>

                <td style={{ padding:"8px 12px", color:C.text, fontWeight:500 }}>{r.Podkategorija}</td>

                <td style={{ padding:"8px 12px", textAlign:"right", color:C.muted }}>{fmt(r.p)}</td>

                <td style={{ padding:"8px 12px", textAlign:"right", color:C.text, fontWeight:600 }}>{fmt(r.o)}</td>

                <td style={{ padding:"8px 12px", textAlign:"right", color:col, fontWeight:600 }}>{r.o-r.p >= 0 ? "+" : ""}{fmt(r.o-r.p)}</td>

                <td style={{ padding:"8px 12px", textAlign:"right" }}>

                  <span style={{ background: col+"22", color: col, borderRadius:4, padding:"2px 8px", fontWeight:700, fontSize:12 }}>

                    {varSign(r.v)} {Math.abs(r.v).toFixed(1)}%

                  </span>

                </td>

              </tr>

            );

          })}

        </tbody>

      </table>

    </div>

  );

}



// ─── WATERFALL CHART ──────────────────────────────────────────────────────────

function WaterfallChart({ monthlyData }) {

  if (!monthlyData.length) return null;

  const last = monthlyData[monthlyData.length - 1];

  const items = [

    { name: "Prihodi", value: last.prihodi_o, type: "positive" },

    { name: "COGS", value: -last.cogs_o, type: "negative" },

    { name: "Bruto dobit", value: last.gross_o, type: "total" },

    { name: "Tr. prodaje", value: -last.prodaja_o, type: "negative" },

    { name: "OpEx", value: -last.opex_o, type: "negative" },

    { name: "EBITDA", value: last.ebitda_o, type: "total" },

  ];



  let running = 0;

  const data = items.map(item => {

    if (item.type === "total") {

      return { ...item, base: 0, bar: item.value };

    }

    const base = item.type === "positive" ? 0 : running + item.value;

    const bar = Math.abs(item.value);

    running += item.value;

    return { ...item, base: Math.max(0, base), bar };

  });



  return (

    <ResponsiveContainer width="100%" height={280}>

      <BarChart data={data} margin={{ top:10, right:20, left:40, bottom:10 }}>

        <CartesianGrid strokeDasharray="3 3" stroke={C.dim} />

        <XAxis dataKey="name" tick={{ fill:C.muted, fontSize:12 }} axisLine={false} tickLine={false} />

        <YAxis tickFormatter={fmtK} tick={{ fill:C.muted, fontSize:11 }} axisLine={false} tickLine={false} />

        <Tooltip content={<CustomTooltip />} />

        <Bar dataKey="base" stackId="a" fill="transparent" />

        <Bar dataKey="bar" stackId="a" radius={[4,4,0,0]}>

          {data.map((d,i) => (

            <Cell key={i} fill={

              d.type === "total" ? C.accent :

              d.type === "positive" ? C.green : C.red

            } />

          ))}

        </Bar>

      </BarChart>

    </ResponsiveContainer>

  );

}



